# ============================================
# IELTS Helper — Environment Variables
# Copy to .env and fill in values
# ============================================

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/ielts_helper

# --- Redis ---
REDIS_URL=redis://localhost:6380

# --- JWT ---
JWT_SECRET=change-me-to-a-random-secret
JWT_REFRESH_SECRET=change-me-to-another-random-secret
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- LLM ---
LLM_PROVIDER=openai
LLM_MODEL_CHEAP=gpt-4o-mini
LLM_MODEL_PREMIUM=gpt-4o
LLM_FALLBACK_PROVIDER=google
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=

# --- Rate Limits ---
WRITING_DAILY_LIMIT=10

# --- NotebookLM ---
NOTEBOOKLM_CACHE_TTL=1800

# --- Admin Seed ---
ADMIN_EMAIL=admin@ieltshelper.local
ADMIN_PASSWORD=Admin1234!

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_DEFAULT_LANG=vi
