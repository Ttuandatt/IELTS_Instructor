// IELTS Helper — Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────

enum UserRole {
  learner
  instructor
  admin
}

enum CefrLevel {
  A2
  B1
  B2
  C1
}

enum ContentStatus {
  draft
  published
}

enum QuestionType {
  matching_headings
  true_false_notgiven
  yes_no_notgiven
  mcq
  matching_information
  matching_features
  matching_sentence_endings
  sentence_completion
  summary_completion
  table_completion
  flowchart_completion
  diagram_label_completion
  short
}

enum TaskType {
  task1
  task2
}

enum ModelTier {
  cheap
  premium
}

enum ProcessingStatus {
  pending
  done
  failed
}

enum ClassroomStatus {
  active
  archived
}

enum ClassroomRole {
  teacher
  student
}

enum LessonContentType {
  text
  video
  passage
  prompt
}

// ─── Users ───────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique @db.VarChar(255)
  password_hash String   @db.VarChar(255)
  display_name  String   @db.VarChar(100)
  role          UserRole @default(learner)
  language      String   @default("vi") @db.VarChar(5)
  theme         String   @default("light") @db.VarChar(10)
  created_at    DateTime @default(now()) @db.Timestamptz()
  updated_at    DateTime @updatedAt @db.Timestamptz()

  // Relations
  passages_created         Passage[]           @relation("PassageCreator")
  prompts_created          Prompt[]            @relation("PromptCreator")
  reading_submissions      ReadingSubmission[]
  writing_submissions      WritingSubmission[]
  reviewed_submissions     WritingSubmission[] @relation("InstructorReviewer")
  classrooms_owned         Classroom[]         @relation("ClassroomOwner")
  classroom_memberships    ClassroomMember[]
  authored_announcements   Announcement[]      @relation("AnnouncementAuthor")
  lesson_submissions       LessonSubmission[]  @relation("LessonSubmissions")
  source_documents         SourceDocument[]    @relation("SourceDocumentUploader")
  import_jobs              ImportJob[]

  @@index([email])
  @@index([role])
  @@map("users")
}

// ─── Content ─────────────────────────────────────────

model Passage {
  id                 String        @id @default(uuid())
  title              String        @db.VarChar(200)
  body               String        @db.Text
  level              CefrLevel
  collection_id      String?
  source_document_id String?
  status             ContentStatus @default(draft)
  created_by         String
  created_at         DateTime      @default(now()) @db.Timestamptz()
  updated_at         DateTime      @updatedAt @db.Timestamptz()

  // Relations
  creator         User                @relation("PassageCreator", fields: [created_by], references: [id])
  collection      Collection?         @relation(fields: [collection_id], references: [id])
  source_document SourceDocument?     @relation(fields: [source_document_id], references: [id])
  questions       Question[]
  submissions     ReadingSubmission[]
  tags            TopicTag[]          @relation("PassageTags")

  @@index([level])
  @@index([status])
  @@index([created_at(sort: Desc)])
  @@index([collection_id])
  @@index([source_document_id])
  @@map("passages")
}

model Question {
  id          String       @id @default(uuid())
  passage_id  String
  type        QuestionType
  prompt      String       @db.Text
  options     Json? // MCQ: ["A. ...", "B. ...", "C. ...", "D. ..."]
  answer_key  Json // MCQ: "B" | Short: ["keyword1", "keyword2"]
  explanation String?      @db.Text
  order_index Int          @default(0)

  // Relations
  passage Passage @relation(fields: [passage_id], references: [id], onDelete: Cascade)

  @@index([passage_id])
  @@index([passage_id, order_index])
  @@map("questions")
}

model Prompt {
  id            String        @id @default(uuid())
  task_type     TaskType
  title         String        @db.VarChar(200)
  prompt_text   String        @db.Text
  level         CefrLevel
  collection_id String?
  status        ContentStatus @default(draft)
  min_words     Int           @default(250)
  created_by    String
  created_at    DateTime      @default(now()) @db.Timestamptz()
  updated_at    DateTime      @updatedAt @db.Timestamptz()

  // Relations
  creator     User                @relation("PromptCreator", fields: [created_by], references: [id])
  collection  Collection?         @relation(fields: [collection_id], references: [id])
  submissions WritingSubmission[]
  tags        TopicTag[]          @relation("PromptTags")

  @@index([task_type])
  @@index([level])
  @@index([status])
  @@index([collection_id])
  @@map("prompts")
}

// ─── Submissions ─────────────────────────────────────

model ReadingSubmission {
  id              String   @id @default(uuid())
  user_id         String
  passage_id      String
  answers         Json // [{question_id, value}]
  score_pct       Float // 0–100
  correct_count   Int
  total_questions Int
  duration_sec    Int?
  timed_out       Boolean  @default(false)
  test_mode       String   @default("practice") @db.VarChar(20)
  completed_at    DateTime @default(now()) @db.Timestamptz()

  // Relations
  user    User    @relation(fields: [user_id], references: [id])
  passage Passage @relation(fields: [passage_id], references: [id])

  @@index([user_id, completed_at(sort: Desc)])
  @@index([passage_id])
  @@map("submissions_reading")
}

model WritingSubmission {
  id                String           @id @default(uuid())
  user_id           String
  prompt_id         String
  content           String           @db.Text
  word_count        Int
  scores            Json? // {TR, CC, LR, GRA, overall} — null when pending
  feedback          Json? // {summary, strengths[], improvements[]}
  model_tier        ModelTier        @default(cheap)
  model_name        String?          @db.VarChar(50)
  turnaround_ms     Int?
  processing_status ProcessingStatus @default(pending)
  error_message     String?          @db.Text
  created_at        DateTime         @default(now()) @db.Timestamptz()
  scored_at         DateTime?        @db.Timestamptz()

  // Instructor review fields (E7: US-702)
  instructor_override_score Float?    // 0–9 (0.5 increments)
  instructor_comment        String?   @db.Text
  reviewed_by               String?
  reviewed_at               DateTime? @db.Timestamptz()

  // Relations
  user     User   @relation(fields: [user_id], references: [id])
  prompt   Prompt @relation(fields: [prompt_id], references: [id])
  reviewer User?  @relation("InstructorReviewer", fields: [reviewed_by], references: [id])

  @@index([user_id, created_at(sort: Desc)])
  @@index([prompt_id])
  @@index([processing_status])
  @@index([reviewed_by])
  @@map("submissions_writing")
}

// ─── Classrooms ────────────────────────────────────────

model Classroom {
  id              String          @id @default(uuid())
  name            String          @db.VarChar(100)
  description     String?         @db.Text
  cover_image_url String?         @db.Text
  invite_code     String          @unique @db.VarChar(8)
  owner_id        String
  status          ClassroomStatus @default(active)
  max_members     Int             @default(50)
  created_at      DateTime        @default(now()) @db.Timestamptz()
  updated_at      DateTime        @updatedAt @db.Timestamptz()

  // Relations
  owner         User              @relation("ClassroomOwner", fields: [owner_id], references: [id])
  members       ClassroomMember[]
  topics        Topic[]
  announcements Announcement[]

  @@index([invite_code])
  @@index([owner_id])
  @@index([status])
  @@map("classrooms")
}

model ClassroomMember {
  id           String        @id @default(uuid())
  classroom_id String
  user_id      String
  role         ClassroomRole @default(student)
  joined_at    DateTime      @default(now()) @db.Timestamptz()

  // Relations
  classroom Classroom @relation(fields: [classroom_id], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [user_id], references: [id])

  @@unique([classroom_id, user_id])
  @@index([user_id])
  @@map("classroom_members")
}

model Topic {
  id           String        @id @default(uuid())
  classroom_id String
  title        String        @db.VarChar(200)
  description  String?       @db.Text
  order_index  Int           @default(0)
  status       ContentStatus @default(draft)
  created_at   DateTime      @default(now()) @db.Timestamptz()

  // Relations
  classroom Classroom @relation(fields: [classroom_id], references: [id], onDelete: Cascade)
  lessons   Lesson[]

  @@index([classroom_id, order_index])
  @@map("topics")
}

model Lesson {
  id               String            @id @default(uuid())
  topic_id         String
  title            String            @db.VarChar(200)
  content          String?           @db.Text
  content_type     LessonContentType @default(text)
  linked_entity_id String?
  attachment_url   String?           @db.Text
  order_index      Int               @default(0)
  status           ContentStatus     @default(draft)
  allow_submit     Boolean           @default(true)
  allow_checkscore Boolean           @default(false)
  created_at       DateTime          @default(now()) @db.Timestamptz()

  // Relations
  topic       Topic              @relation(fields: [topic_id], references: [id], onDelete: Cascade)
  submissions LessonSubmission[]

  @@index([topic_id, order_index])
  @@map("lessons")
}

model LessonSubmission {
  id         String   @id @default(uuid())
  lesson_id  String
  user_id    String
  content    String   @db.Text
  word_count Int
  status     String   @default("submitted") @db.VarChar(20) // submitted | graded
  score      Float?   // teacher-assigned score
  feedback   String?  @db.Text
  created_at DateTime @default(now()) @db.Timestamptz()

  // Relations
  lesson Lesson @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
  user   User   @relation("LessonSubmissions", fields: [user_id], references: [id])

  @@index([lesson_id, created_at(sort: Desc)])
  @@index([user_id])
  @@map("lesson_submissions")
}

model Announcement {
  id           String   @id @default(uuid())
  classroom_id String
  author_id    String
  message      String   @db.Text
  created_at   DateTime @default(now()) @db.Timestamptz()

  // Relations
  classroom Classroom @relation(fields: [classroom_id], references: [id], onDelete: Cascade)
  author    User      @relation("AnnouncementAuthor", fields: [author_id], references: [id])

  @@index([classroom_id, created_at])
  @@map("announcements")
}

// ─── Resource & Import Management ────────────────────────────────

model SourceDocument {
  id          String           @id @default(uuid())
  file_name   String           @db.VarChar(255)
  file_url    String           @db.Text
  uploaded_by String
  status      ProcessingStatus @default(pending)
  created_at  DateTime         @default(now()) @db.Timestamptz()

  // Relations
  uploader    User        @relation("SourceDocumentUploader", fields: [uploaded_by], references: [id])
  passages    Passage[]
  import_jobs ImportJob[]

  @@index([uploaded_by])
  @@index([status])
  @@map("source_documents")
}

model ImportJob {
  id              String           @id @default(uuid())
  user_id         String
  document_id     String
  status          ProcessingStatus @default(pending)
  parsed_raw_data Json?
  error_message   String?          @db.Text
  created_at      DateTime         @default(now()) @db.Timestamptz()
  updated_at      DateTime         @updatedAt @db.Timestamptz()

  // Relations
  user            User           @relation(fields: [user_id], references: [id])
  source_document SourceDocument @relation(fields: [document_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([document_id])
  @@index([status])
  @@map("import_jobs")
}

model Collection {
  id          String    @id @default(uuid())
  name        String    @unique @db.VarChar(100)
  description String?   @db.Text
  created_at  DateTime  @default(now()) @db.Timestamptz()
  updated_at  DateTime  @updatedAt @db.Timestamptz()

  // Relations
  passages    Passage[]
  prompts     Prompt[]

  @@map("collections")
}

model TopicTag {
  id   String @id @default(uuid())
  name String @unique @db.VarChar(50)

  // Relations
  passages Passage[] @relation("PassageTags")
  prompts  Prompt[]  @relation("PromptTags")

  @@map("topic_tags")
}
